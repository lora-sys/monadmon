# Chain RPC — auto-selects between Monad testnet and local anvil based on URL.
# For local dev against Anvil, set to http://127.0.0.1:8545 (chain id 31337).
NEXT_PUBLIC_MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# Deployed contract addresses (filled by deploy step).
NEXT_PUBLIC_MONSTER_NFT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_GENESIS_MINTER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_BATTLE_ADDRESS=0x0000000000000000000000000000000000000000
