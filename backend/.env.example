# Indexer configuration
PORT=3001

# RPC — set to http://127.0.0.1:8545 for local anvil, https://testnet-rpc.monad.xyz for testnet
RPC_URL=http://127.0.0.1:8545

# Deployed contract addresses (filled after `forge script script/Deploy.s.sol ... --broadcast`)
MONSTER_NFT_ADDRESS=0xe7f1725e7734ce288f8367e1bb143e90bb3f0512
BATTLE_ADDRESS=0xdc64a140aa3e981100a9beca4e685f962f0cf6c9

# Reorg safety: number of confirmations to wait before persisting
CONFIRMATIONS=5

# Polling interval in ms (used when not using websockets)
POLL_INTERVAL_MS=2000
